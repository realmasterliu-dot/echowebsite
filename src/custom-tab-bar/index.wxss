/* 对齐 H5 Dock.css — Apple Liquid Glass 悬浮底栏 */

.dock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  justify-content: center;
  pointer-events: none;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  transform: translate3d(0, 0, 0);
  opacity: 1;
  /* 回显稍慢 */
  transition:
    transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
    opacity 0.42s ease;
}

/* 下滑：整栏向下收起（收起更快） */
.dock--collapsed {
  transform: translate3d(0, calc(100% + 48rpx), 0);
  opacity: 0;
  transition:
    transform 0.26s cubic-bezier(0.4, 0, 1, 1),
    opacity 0.2s ease;
}

.dock__inner {
  pointer-events: auto;
  max-width: 640rpx;
  width: auto;
  padding: 10rpx;
  background: rgba(255, 255, 255, 0.42);
  /* 真机支持时显示毛玻璃；不支持时半透明白底仍呈悬浮感 */
  backdrop-filter: blur(24px) saturate(1.8);
  -webkit-backdrop-filter: blur(24px) saturate(1.8);
  border-radius: 48rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  box-shadow:
    0 16rpx 64rpx rgba(31, 38, 135, 0.1),
    0 4rpx 16rpx rgba(0, 0, 0, 0.04),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.55);
  box-sizing: border-box;
}

.dock__track {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  justify-content: center;
  gap: 4rpx;
}

.dock__item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 18rpx 24rpx;
  min-width: 112rpx;
  border-radius: 36rpx;
  box-sizing: border-box;
}

.dock__item--active {
  background: rgba(255, 85, 0, 0.08);
}

.dock__icon {
  width: 44rpx;
  height: 44rpx;
  display: block;
}

.dock__label {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.02em;
  line-height: 1.2;
  white-space: nowrap;
  opacity: 0.75;
}

.dock__item--active .dock__label {
  opacity: 1;
}

.dock__indicator {
  position: absolute;
  bottom: 6rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #ff5500;
}
